{
  "tests": [
    {
      "name": "batch_video_generation",
      "input": {
        "tasks": [
          {
            "prompts": [
              [
                "running man, grab the gun",
                "blurry, low quality, distorted"
              ],
              [
                "the man keeps running toward the camera",
                "blurry, low quality, distorted",
                97
              ]
            ],
            "ouput_video": "/tmp/runpod-tests/task_01/output.mp4"
          },
          {
            "prompts": [
              [
                "the man turns and runs away from camera",
                "blurry, low quality, distorted"
              ]
            ],
            "ouput_video": "/tmp/runpod-tests/task_02/output.mp4"
          }
        ],
        "seed": 2025,
        "frame_rate": 24,
        "sampler": "euler",
        "steps": 4
      },
      "timeout": 1800000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "env": [
      {
        "key": "ENV_KEY_HERE",
        "value": "ENV_VALUE_HERE"
      }
    ],
    "allowedCudaVersions": [
      "12.7",
      "12.6",
      "12.5",
      "12.4",
      "12.3",
      "12.2",
      "12.1",
      "12.0"
    ]
  }
}
